# ============================================================
# REQUIRED — Authentication
# ============================================================

# Password to log in to the app
ADMIN_PASSWORD=choose-a-strong-password

# Session encryption secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# The URL the app is running on
# For local dev: http://localhost:3000
# For Vercel: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000


# ============================================================
# REQUIRED — Vault
# ============================================================
# At least one vault source must be configured.
# Set VAULT_CONFIG as a single JSON environment variable.
#
# Local vault   — reads directly from disk, localhost only
# Remote vault  — GitHub or GitLab, works everywhere including Vercel
# Both          — enables automatic sync between local and remote
#
# On localhost: the setup wizard writes vault-config.json automatically.
# On Vercel: set VAULT_CONFIG as an environment variable in your project settings.
#
# IMPORTANT: the value must be on a single line (no line breaks).

# Local only:
# VAULT_CONFIG={"local":{"path":"/Users/you/my-vault"}}

# GitHub:
# VAULT_CONFIG={"remote":{"provider":"github","token":"github_pat_xxxx","owner":"yourusername","repo":"your-vault-repo","branch":"main"}}

# GitLab (self-hosted):
# VAULT_CONFIG={"remote":{"provider":"gitlab","token":"glpat-xxxx","namespace":"yourusername","project":"your-vault-repo","branch":"main","url":"https://gitlab.yourcompany.com"}}

# Local + GitHub sync:
# VAULT_CONFIG={"remote":{"provider":"github","token":"github_pat_xxxx","owner":"yourusername","repo":"your-vault-repo","branch":"main"},"local":{"path":"/Users/you/my-vault"}}


# ============================================================
# OPTIONAL — Gmail integration
# ============================================================
# Enables searching and summarising Gmail emails from person notes.
# If not set, Gmail functionality is hidden throughout the app.

# Google OAuth App credentials
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable Gmail API. Callback URL: <NEXTAUTH_URL>/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxxx
# GOOGLE_CLIENT_SECRET=xxxx

# Anthropic API key — required for AI email summarisation
# Get at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxx
