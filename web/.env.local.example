# GitHub PAT (fine-grained, read/write access to vault repo contents)
GITHUB_PAT=ghp_xxxx

# Vault GitHub repo
GITHUB_VAULT_OWNER=yourusername
GITHUB_VAULT_REPO=your-vault-repo

# Optional: default branch of vault repo (default: main)
# GITHUB_VAULT_BRANCH=main

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=xxxx
GITHUB_CLIENT_SECRET=xxxx

# Your numeric GitHub user ID (run: curl https://api.github.com/users/YOUR_USERNAME | grep '"id"')
ALLOWED_GITHUB_USER_ID=12345678

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Your deployment URL
NEXTAUTH_URL=http://localhost:3000

# Google OAuth App credentials (for Gmail integration)
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable Gmail API, add redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxx
GOOGLE_CLIENT_SECRET=xxxx

# Anthropic API key (for AI summarization in Gmail integration)
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxx
