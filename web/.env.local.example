# ============================================================
# REQUIRED — Authentication
# ============================================================

# GitHub OAuth App credentials
# Create at: GitHub → Settings → Developer Settings → OAuth Apps
# Callback URL: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=xxxx
GITHUB_CLIENT_SECRET=xxxx

# Your numeric GitHub user ID — only this account can sign in
# Find with: curl https://api.github.com/users/YOUR_USERNAME | grep '"id"'
ALLOWED_GITHUB_USER_ID=12345678

# Session encryption secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# The URL the app is running on
NEXTAUTH_URL=http://localhost:3000


# ============================================================
# REQUIRED — Vault access
# ============================================================
# These can also be configured via the Settings screen in the app.

# Fine-grained GitHub PAT with Contents: Read and write on the vault repo
# Create at: GitHub → Settings → Developer Settings → Personal access tokens
GITHUB_PAT=ghp_xxxx

# The GitHub repository used as your vault
GITHUB_VAULT_OWNER=yourusername
GITHUB_VAULT_REPO=your-vault-repo

# Branch to use (default: main)
# GITHUB_VAULT_BRANCH=main


# ============================================================
# OPTIONAL — Gmail integration
# ============================================================
# Enables searching and summarising Gmail emails from person notes.
# If not set, Gmail functionality is hidden throughout the app.

# Google OAuth App credentials
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable Gmail API. Callback URL: <NEXTAUTH_URL>/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxxx
# GOOGLE_CLIENT_SECRET=xxxx

# Anthropic API key — required for AI email summarisation
# Get at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxx
