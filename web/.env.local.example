# ============================================================
# REQUIRED — Authentication
# ============================================================

# Password to log in to the app
ADMIN_PASSWORD=choose-a-strong-password

# Session encryption secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# The URL the app is running on
# For local dev: http://localhost:3000
# For Vercel: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000


# ============================================================
# REQUIRED — GitHub Vault
# ============================================================
# The GitHub repository that stores your markdown vault.
# This is always configured via environment variables (not in the app's Settings UI).

# Fine-grained PAT with Contents: Read and write on the vault repo
# Create at: GitHub → Settings → Developer Settings → Personal access tokens → Fine-grained tokens
GITHUB_PAT=github_pat_xxxx
GITHUB_VAULT_OWNER=yourusername
GITHUB_VAULT_REPO=your-vault-repo
GITHUB_VAULT_BRANCH=main


# ============================================================
# OPTIONAL — Local Vault (localhost only)
# ============================================================
# Absolute path to your local Obsidian vault folder.
# When set alongside GitHub, auto-sync between local and GitHub becomes available
# in the app's Settings screen.
# This setting is NOT used on Vercel (no local filesystem).

# VAULT_PATH=/Users/you/my-vault


# ============================================================
# OPTIONAL — Gmail integration
# ============================================================
# Enables searching and summarising Gmail emails from person notes.
# If not set, Gmail functionality is hidden throughout the app.

# Google OAuth App credentials
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable Gmail API. Callback URL: <NEXTAUTH_URL>/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxxx
# GOOGLE_CLIENT_SECRET=xxxx

# Anthropic API key — required for AI email summarisation
# Get at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxx
